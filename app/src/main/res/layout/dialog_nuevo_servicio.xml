<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#1A2436">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nuevo Servicio"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="15dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Seleccionar Cliente"
        android:textColor="#AAA"
        android:textSize="14sp"/>

    <Spinner
        android:id="@+id/spinnerClientes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:backgroundTint="@android:color/white"/>

    <EditText
        android:id="@+id/etTipoServicio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tipo de servicio (Ej: Instalación)"
        android:textColorHint="#888"
        android:textColor="@android:color/white"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Estado"
        android:textColor="#AAA"
        android:textSize="14sp"/>

    <Spinner
        android:id="@+id/spinnerEstado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/estados_servicio"
        android:layout_marginBottom="10dp"
        android:backgroundTint="@android:color/white"/>

    <EditText
        android:id="@+id/etManoObra"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Mano de obra ($)"
        android:inputType="numberDecimal"
        android:textColorHint="#888"
        android:textColor="@android:color/white"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/etMateriales"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Materiales ($)"
        android:inputType="numberDecimal"
        android:textColorHint="#888"
        android:textColor="@android:color/white"
        android:layout_marginBottom="10dp"/>

</LinearLayout>